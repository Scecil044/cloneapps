    "ioredis": "^5.0.4",
    "isomorphic-fetch": "^3.0.0",
    "joi": "^17.3.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "mailcomposer": "^4.0.2",
    "moment": "^2.29.2",
    "moment-timezone": "^0.5.34",
    "mongodb": "^2.2.12",
    "mongoose": "^5.7.7",
    "morgan": "^1.9.1",
