    "@nathangroup/claim-email": "^3.0.0",
    "@nathangroup/leave": "^2.0.5",
    "@nathangroup/leave_email": "^3.0.0",
    "@nathangroup/letter": "^2.0.2",
    "@nathangroup/letter-email": "^1.0.11",
    "@nathangroup/wfh": "^2.0.3",
    "@nathangroup/wfh_email": "^2.2.1",
    "@sendgrid/mail": "^8.1.3",
    "aws-sdk": "^2.1435.0",
    "axios": "^1.7.4",
